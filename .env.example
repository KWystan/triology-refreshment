# ─── Supabase (client) ──────────────────────────────────────
# These are safe to expose client-side via Vite.
# Copy to client/.env
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase (server) ──────────────────────────────────────
# Copy to server/.env — the secret key is sensitive.
# See server/.env.example for all server vars.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
SUPABASE_SECRET_KEY=your-secret-key-here

# ─── Server ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
SESSION_SECRET=change-me-to-a-random-secret
