# Copy to .env and fill in your values.
# Run: cp .env.example .env

# ─── Server ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Supabase (@supabase/server) ────────────────────────────
# Get these from https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Publishable (anon) key — safe for server-side context creation
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
# Secret (service-role) key — NEVER expose to the client
SUPABASE_SECRET_KEY=your-secret-key-here
# JWKS URL for JWT verification (derived from SUPABASE_URL if omitted)
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# ─── CORS ───────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173

# ─── Session ────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-secret

# ─── Cloudinary ────────────────────────────────────────────
# Get from https://cloudinary.com/console
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── Admin ─────────────────────────────────────────────────
# Email of the admin who can manage menu CRUD
ADMIN_EMAIL=admin@example.com
