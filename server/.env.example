# Copy to .env and fill in your values.
# Run: cp .env.example .env

# ─── Server ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Firebase Auth (Web API Key for REST API) ─────────────────
# Get this from Firebase Console → Project Settings → General → Web API Key
FIREBASE_WEB_API_KEY=your-firebase-web-api-key-here

# ─── CORS ───────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173

# ─── Session ────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-secret

# ─── Google OAuth ──────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application) with redirect URI:
#   http://localhost:4000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Cloudinary ────────────────────────────────────────────
# Get from https://cloudinary.com/console
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── Admin ─────────────────────────────────────────────────
# Email of the admin who can manage menu CRUD
ADMIN_EMAIL=admin@example.com
